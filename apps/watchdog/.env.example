# Watchdog — monitors and relaunches POS (US-9.2)
WATCHDOG_ENABLED=true
WATCHDOG_CHECK_INTERVAL_MS=5000
WATCHDOG_MAX_RESTARTS=3
WATCHDOG_RESTART_WINDOW_MS=600000
WATCHDOG_LOG_FILE=logs/watchdog.log
WATCHDOG_POS_CWD=
# Shell command to launch POS (dev example below)
WATCHDOG_POS_COMMAND=npm run electron:dev -w @venue-pos/pos
# Production kiosk: set ELECTRON_IS_KIOSK=true in POS env
# WATCHDOG_POS_COMMAND=electron path\to\pos\electron\main.cjs

# Ops alert ingest (must match API OPS_INGEST_SECRET)
# OPS_API_URL=http://127.0.0.1:3000
# OPS_INGEST_SECRET=dev-ops-ingest-secret
