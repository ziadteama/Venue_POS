generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VenueType {
  standard
  anchor
}

enum ReceiptTemplate {
  standard
  compact
  detailed
}

enum UserRole {
  hub_owner
  hub_manager
  venue_manager
  cashier
  kitchen_staff
  system_admin
}

enum MenuStatus {
  draft
  published
  archived
}

enum OrderStatus {
  draft
  sent
  partially_ready
  ready
  served
  billed
  closed
  voided
}

enum OrderItemKitchenStatus {
  pending
  in_progress
  ready
  served
}

enum ChequeStatus {
  open
  paid
  voided
}

enum ChequeServiceMode {
  dine_in
  takeaway
}

enum ChequeDiscountAction {
  apply
  change
  remove
}

enum PaymentMethod {
  cash
  card
  voucher
}

enum ShiftStatus {
  open
  closed
}

enum ShiftEventAction {
  open
  close
}

enum ApprovalRequestType {
  discount
  refund
}

enum ApprovalRequestStatus {
  pending
  approved
  rejected
}

model Venue {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nameEn             String          @map("name_en") @db.VarChar(255)
  nameAr             String          @map("name_ar") @db.VarChar(255)
  type               VenueType       @default(standard)
  currency           String          @default("EGP") @db.VarChar(3)
  isActive           Boolean         @default(true) @map("is_active")
  taxRate            Decimal         @default(0) @map("tax_rate") @db.Decimal(5, 4)
  taxInclusive       Boolean         @default(false) @map("tax_inclusive")
  serviceRate        Decimal         @default(0) @map("service_rate") @db.Decimal(5, 4)
  serviceEnabled     Boolean         @default(false) @map("service_enabled")
  receiptTemplate    ReceiptTemplate @default(standard) @map("receipt_template")
  kitchenPrinterHost String?         @map("kitchen_printer_host") @db.VarChar(255)
  kitchenPrinterPort Int             @default(9100) @map("kitchen_printer_port")
  receiptPrinterHost String?         @map("receipt_printer_host") @db.VarChar(255)
  receiptPrinterPort Int             @default(9100) @map("receipt_printer_port")
  tables             Json            @default("[]") @db.JsonB
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  users            User[]
  terminals        Terminal[]
  venueMenu        VenueMenu?
  categories       Category[]
  modifierGroups   ModifierGroup[]
  orders           Order[]
  cheques          Cheque[]
  shifts           Shift[]
  approvalRequests ManagerApprovalRequest[]
  configAudits     VenueConfigAudit[]
  auditLogs        AuditLog[]
  opsEvents        OpsEvent[]
  billingAsAnchor  VenueBillingConfig[]     @relation("BillingAnchor")
  billingAsTarget  VenueBillingConfig[]     @relation("BillingTarget")
  floorTables      FloorTable[]

  @@map("venues")
}

/// Cross-venue billing pairs. When an anchor venue is linked to a target venue,
/// an anchor terminal may settle the target venue's open orders on a single cheque.
model VenueBillingConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  anchorVenueId String   @map("anchor_venue_id") @db.Uuid
  targetVenueId String   @map("target_venue_id") @db.Uuid
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  anchorVenue Venue @relation("BillingAnchor", fields: [anchorVenueId], references: [id], onDelete: Cascade)
  targetVenue Venue @relation("BillingTarget", fields: [targetVenueId], references: [id], onDelete: Cascade)

  @@unique([anchorVenueId, targetVenueId], map: "uq_venue_billing_pair")
  @@index([anchorVenueId], map: "idx_venue_billing_anchor")
  @@index([targetVenueId], map: "idx_venue_billing_target")
  @@map("venue_billing_configs")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String?  @unique @db.VarChar(100)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  pinHash      String?  @map("pin_hash") @db.VarChar(255)
  cardUid      String?  @map("card_uid") @db.VarChar(100)
  role         UserRole
  venueId      String?  @map("venue_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue              Venue?                    @relation(fields: [venueId], references: [id])
  orders             Order[]
  voidsApproved      OrderVoidAudit[]          @relation("VoidApprover")
  voidsCashier       OrderVoidAudit[]          @relation("VoidCashier")
  compsApproved      OrderItemCompAudit[]      @relation("CompApprover")
  compsCashier       OrderItemCompAudit[]      @relation("CompCashier")
  transfersApproved  ChequeItemTransferAudit[] @relation("TransferApprover")
  transfersCashier   ChequeItemTransferAudit[] @relation("TransferCashier")
  discountsInitiated ChequeDiscountAudit[]     @relation("DiscountInitiator")
  discountsApproved  ChequeDiscountAudit[]     @relation("DiscountApprover")
  discountsCashier   ChequeDiscountAudit[]     @relation("DiscountCashier")
  refundsInitiated   Refund[]                  @relation("RefundInitiator")
  refundsApproved    Refund[]                  @relation("RefundApprover")
  refundsCashier     Refund[]                  @relation("RefundCashier")
  approvalsInitiated ManagerApprovalRequest[]  @relation("ApprovalInitiator")
  approvalsResolved  ManagerApprovalRequest[]  @relation("ApprovalResolver")
  approvalsCashier   ManagerApprovalRequest[]  @relation("ApprovalCashier")
  chequesOpened      Cheque[]                  @relation("ChequeCashier")
  payments           Payment[]
  shifts             Shift[]
  shiftEvents        ShiftEvent[]
  venueConfigAudits  VenueConfigAudit[]
  auditLogs          AuditLog[]

  @@index([venueId], map: "idx_users_venue")
  @@index([role], map: "idx_users_role")
  @@map("users")
}

model Terminal {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId            String    @map("venue_id") @db.Uuid
  name               String?   @db.VarChar(100)
  secretHash         String    @map("secret_hash") @db.VarChar(255)
  isActive           Boolean   @default(true) @map("is_active")
  isCoordinator      Boolean   @default(false) @map("is_coordinator")
  coordinatorLanHost String?   @map("coordinator_lan_host") @db.VarChar(255)
  assignedLanHost    String?   @map("assigned_lan_host") @db.VarChar(255)
  lastSeenAt         DateTime? @map("last_seen_at") @db.Timestamptz(6)
  syncQueueDepth     Int       @default(0) @map("sync_queue_depth")
  lastLanHost        String?   @map("last_lan_host") @db.VarChar(255)
  lastLanPort        Int?      @map("last_lan_port")
  lastAgentPriority  Int?      @map("last_agent_priority")
  lastClusterMode    String?   @map("last_cluster_mode") @db.VarChar(32)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue      Venue       @relation(fields: [venueId], references: [id])
  orders     Order[]
  cheques    Cheque[]
  shifts     Shift[]
  syncEvents SyncEvent[]
  opsEvents  OpsEvent[]

  @@index([venueId], map: "idx_terminals_venue")
  @@map("terminals")
}

/// Idempotent client sync deduplication (offline replay).
model SyncEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  syncId      String   @unique @map("sync_id") @db.Uuid
  terminalId  String   @map("terminal_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(100)
  resultJson  Json?    @map("result_json") @db.JsonB
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  terminal Terminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  @@index([terminalId], map: "idx_sync_events_terminal")
  @@map("sync_events")
}

/// Hub-wide physical table master + occupancy (one table, all venues).
model FloorTable {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableLabel                String   @unique @map("table_label") @db.VarChar(50)
  sortOrder                 Int      @default(0) @map("sort_order")
  isActive                  Boolean  @default(true) @map("is_active")
  venueId                   String?  @map("venue_id") @db.Uuid
  occupiedByChequeId        String?  @map("occupied_by_cheque_id") @db.Uuid
  occupiedCrossVenueGroupId String?  @map("occupied_cross_venue_group_id") @db.Uuid
  lockedByTerminalId        String?  @map("locked_by_terminal_id") @db.Uuid
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue   Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  cheques Cheque[]
  orders  Order[]

  @@index([venueId], map: "idx_floor_tables_venue")
  @@map("floor_tables")
}

/// Hub-wide tax and service charge (one rate for all venues).
model HubBilling {
  id             String   @id @default("hub") @db.VarChar(16)
  taxRate        Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 4)
  taxInclusive   Boolean  @default(false) @map("tax_inclusive")
  serviceRate    Decimal  @default(0) @map("service_rate") @db.Decimal(5, 4)
  serviceEnabled Boolean  @default(false) @map("service_enabled")
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("hub_billing")
}

model VenueMenu {
  venueId     String     @id @map("venue_id") @db.Uuid
  status      MenuStatus @default(draft)
  publishedAt DateTime?  @map("published_at") @db.Timestamptz(6)
  versionHash String?    @map("version_hash") @db.VarChar(64)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("venue_menus")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId   String   @map("venue_id") @db.Uuid
  nameEn    String   @map("name_en") @db.VarChar(255)
  nameAr    String   @map("name_ar") @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  items MenuItem[]

  @@index([venueId], map: "idx_categories_venue")
  @@map("categories")
}

model MenuItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  nameEn        String   @map("name_en") @db.VarChar(255)
  nameAr        String   @map("name_ar") @db.VarChar(255)
  descriptionEn String?  @map("description_en") @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  price         Decimal  @db.Decimal(10, 2)
  taxRate       Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 4)
  imageUrl      String?  @map("image_url") @db.VarChar(500)
  isAvailable   Boolean  @default(true) @map("is_available")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  category       Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  modifierGroups MenuItemModifier[]

  @@index([categoryId], map: "idx_menu_items_category")
  @@map("menu_items")
}

model ModifierGroup {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId      String   @map("venue_id") @db.Uuid
  nameEn       String   @map("name_en") @db.VarChar(255)
  nameAr       String   @map("name_ar") @db.VarChar(255)
  minSelection Int      @default(0) @map("min_selection")
  maxSelection Int      @default(1) @map("max_selection")
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue   Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  options ModifierOption[]
  items   MenuItemModifier[]

  @@index([venueId], map: "idx_modifier_groups_venue")
  @@map("modifier_groups")
}

model ModifierOption {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modifierGroupId String   @map("modifier_group_id") @db.Uuid
  nameEn          String   @map("name_en") @db.VarChar(255)
  nameAr          String   @map("name_ar") @db.VarChar(255)
  priceDelta      Decimal  @default(0) @map("price_delta") @db.Decimal(10, 2)
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@index([modifierGroupId], map: "idx_modifier_options_group")
  @@map("modifier_options")
}

model MenuItemModifier {
  menuItemId      String @map("menu_item_id") @db.Uuid
  modifierGroupId String @map("modifier_group_id") @db.Uuid

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([menuItemId, modifierGroupId])
  @@map("menu_item_modifiers")
}

model Order {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId      String      @map("venue_id") @db.Uuid
  terminalId   String?     @map("terminal_id") @db.Uuid
  cashierId    String      @map("cashier_id") @db.Uuid
  orderNumber  Int         @map("order_number")
  businessDate DateTime    @map("business_date") @db.Date
  tableLabel   String?     @map("table_label") @db.VarChar(50)
  floorTableId String?     @map("floor_table_id") @db.Uuid
  status       OrderStatus @default(draft)
  sentAt       DateTime?   @map("sent_at") @db.Timestamptz(6)
  openedAt     DateTime    @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt     DateTime?   @map("closed_at") @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue      Venue           @relation(fields: [venueId], references: [id])
  terminal   Terminal?       @relation(fields: [terminalId], references: [id])
  cashier    User            @relation(fields: [cashierId], references: [id])
  floorTable FloorTable?     @relation(fields: [floorTableId], references: [id], onDelete: SetNull)
  items      OrderItem[]
  voidAudit  OrderVoidAudit?
  chequeLink ChequeOrder?

  @@unique([venueId, businessDate, orderNumber], map: "uq_orders_venue_business_day_number")
  @@index([venueId], map: "idx_orders_venue")
  @@index([venueId, businessDate], map: "idx_orders_venue_business_date")
  @@index([status], map: "idx_orders_status")
  @@index([floorTableId], map: "idx_orders_floor_table")
  @@map("orders")
}

model OrderItem {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String                 @map("order_id") @db.Uuid
  menuItemId        String                 @map("menu_item_id") @db.Uuid
  quantity          Int                    @default(1)
  unitPrice         Decimal                @map("unit_price") @db.Decimal(10, 2)
  modifiersSnapshot Json?                  @map("modifiers_snapshot")
  kitchenStatus     OrderItemKitchenStatus @default(pending) @map("kitchen_status")
  isComped          Boolean                @default(false) @map("is_comped")
  billingChequeId   String?                @map("billing_cheque_id") @db.Uuid
  paidAt            DateTime?              @map("paid_at") @db.Timestamptz(6)
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  order          Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem       MenuItem                  @relation(fields: [menuItemId], references: [id])
  compAudit      OrderItemCompAudit?
  transferAudits ChequeItemTransferAudit[]
  billingCheque  Cheque?                   @relation("ItemBillingCheque", fields: [billingChequeId], references: [id])

  @@index([orderId], map: "idx_order_items_order")
  @@index([billingChequeId], map: "idx_order_items_billing_cheque")
  @@map("order_items")
}

model OrderVoidAudit {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String   @unique @map("order_id") @db.Uuid
  cashierId  String   @map("cashier_id") @db.Uuid
  approverId String   @map("approver_id") @db.Uuid
  reason     String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cashier  User  @relation("VoidCashier", fields: [cashierId], references: [id])
  approver User  @relation("VoidApprover", fields: [approverId], references: [id])

  @@index([cashierId], map: "idx_void_audit_cashier")
  @@index([approverId], map: "idx_void_audit_approver")
  @@map("order_void_audits")
}

model OrderItemCompAudit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId String   @unique @map("order_item_id") @db.Uuid
  chequeId    String   @map("cheque_id") @db.Uuid
  cashierId   String   @map("cashier_id") @db.Uuid
  approverId  String   @map("approver_id") @db.Uuid
  reason      String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  cheque    Cheque    @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  cashier   User      @relation("CompCashier", fields: [cashierId], references: [id])
  approver  User      @relation("CompApprover", fields: [approverId], references: [id])

  @@index([chequeId], map: "idx_comp_audit_cheque")
  @@map("order_item_comp_audits")
}

/// Hub-wide daily cheque number sequence (shared across all venues).
model ChequeNumberCounter {
  businessDate DateTime @id @map("business_date") @db.Date
  lastNumber   Int      @default(0) @map("last_number")

  @@map("cheque_number_counters")
}

model Cheque {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId           String       @map("venue_id") @db.Uuid
  terminalId        String?      @map("terminal_id") @db.Uuid
  cashierId         String       @map("cashier_id") @db.Uuid
  chequeNumber      Int          @map("cheque_number")  
  businessDate      DateTime     @map("business_date") @db.Date
  tableLabel        String       @map("table_label") @db.VarChar(50)
  floorTableId      String?      @map("floor_table_id") @db.Uuid
  serviceMode       ChequeServiceMode @default(dine_in) @map("service_mode")
  splitLabel        String?      @map("split_label") @db.VarChar(50)
  splitAmount       Decimal?     @map("split_amount") @db.Decimal(10, 2)
  discountAmount    Decimal      @default(0) @map("discount_amount") @db.Decimal(10, 2)
  parentChequeId    String?      @map("parent_cheque_id") @db.Uuid
  isCrossVenue      Boolean      @default(false) @map("is_cross_venue")
  crossVenueGroupId String?      @map("cross_venue_group_id") @db.Uuid
  status                      ChequeStatus @default(open)
  prePaymentCheckPrintCount   Int          @default(0) @map("pre_payment_check_print_count")
  openedAt                    DateTime     @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt          DateTime?    @map("closed_at") @db.Timestamptz(6)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue             Venue                     @relation(fields: [venueId], references: [id])
  terminal          Terminal?                 @relation(fields: [terminalId], references: [id])
  cashier           User                      @relation("ChequeCashier", fields: [cashierId], references: [id])
  floorTable        FloorTable?               @relation(fields: [floorTableId], references: [id], onDelete: SetNull)
  orders            ChequeOrder[]
  payments          Payment[]
  compAudits        OrderItemCompAudit[]
  billedItems       OrderItem[]               @relation("ItemBillingCheque")
  parentCheque      Cheque?                   @relation("ChequeSplit", fields: [parentChequeId], references: [id])
  childCheques      Cheque[]                  @relation("ChequeSplit")
  transferAuditsOut ChequeItemTransferAudit[] @relation("TransferSource")
  transferAuditsIn  ChequeItemTransferAudit[] @relation("TransferTarget")
  discountAudits    ChequeDiscountAudit[]
  refunds           Refund[]
  approvalRequests  ManagerApprovalRequest[]

  @@unique([venueId, businessDate, chequeNumber], map: "uq_cheques_venue_business_day_number")
  @@index([venueId, status], map: "idx_cheques_venue_status")
  @@index([venueId, businessDate], map: "idx_cheques_venue_business_date")
  @@index([venueId, tableLabel], map: "idx_cheques_venue_table")
  @@index([parentChequeId], map: "idx_cheques_parent")
  @@index([crossVenueGroupId], map: "idx_cheques_cross_group")
  @@index([floorTableId, status], map: "idx_cheques_floor_table_status")
  @@index([venueId, serviceMode, status], map: "idx_cheques_venue_service_mode")
  @@map("cheques")
}

model ChequeOrder {
  chequeId  String   @map("cheque_id") @db.Uuid
  orderId   String   @unique @map("order_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  cheque Cheque @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@id([chequeId, orderId])
  @@index([chequeId], map: "idx_cheque_orders_cheque")
  @@map("cheque_orders")
}

model ChequeItemTransferAudit {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceChequeId String   @map("source_cheque_id") @db.Uuid
  targetChequeId String   @map("target_cheque_id") @db.Uuid
  orderItemId    String   @map("order_item_id") @db.Uuid
  cashierId      String   @map("cashier_id") @db.Uuid
  approverId     String   @map("approver_id") @db.Uuid
  reason         String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sourceCheque Cheque    @relation("TransferSource", fields: [sourceChequeId], references: [id])
  targetCheque Cheque    @relation("TransferTarget", fields: [targetChequeId], references: [id])
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  cashier      User      @relation("TransferCashier", fields: [cashierId], references: [id])
  approver     User      @relation("TransferApprover", fields: [approverId], references: [id])

  @@index([sourceChequeId], map: "idx_transfer_audit_source")
  @@index([targetChequeId], map: "idx_transfer_audit_target")
  @@map("cheque_item_transfer_audits")
}

model Payment {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chequeId    String        @map("cheque_id") @db.Uuid
  cashierId   String        @map("cashier_id") @db.Uuid
  shiftId     String?       @map("shift_id") @db.Uuid
  method      PaymentMethod
  amount      Decimal       @db.Decimal(10, 2)
  cardLast4   String?       @map("card_last4") @db.VarChar(4)
  processedAt DateTime      @default(now()) @map("processed_at") @db.Timestamptz(6)

  cheque  Cheque   @relation(fields: [chequeId], references: [id])
  cashier User     @relation(fields: [cashierId], references: [id])
  shift   Shift?   @relation(fields: [shiftId], references: [id])
  refunds Refund[]

  @@index([chequeId], map: "idx_payments_cheque")
  @@index([shiftId], map: "idx_payments_shift")
  @@map("payments")
}

model ChequeDiscountAudit {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chequeId       String               @map("cheque_id") @db.Uuid
  cashierId      String               @map("cashier_id") @db.Uuid
  initiatorId    String               @map("initiator_id") @db.Uuid
  approverId     String               @map("approver_id") @db.Uuid
  action         ChequeDiscountAction @default(apply)
  amount         Decimal              @db.Decimal(10, 2)
  previousAmount Decimal?             @map("previous_amount") @db.Decimal(10, 2)
  percent        Decimal?             @db.Decimal(5, 2)
  reason         String               @db.Text
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  cheque    Cheque @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  cashier   User   @relation("DiscountCashier", fields: [cashierId], references: [id])
  initiator User   @relation("DiscountInitiator", fields: [initiatorId], references: [id])
  approver  User   @relation("DiscountApprover", fields: [approverId], references: [id])

  @@index([chequeId], map: "idx_discount_audit_cheque")
  @@map("cheque_discount_audits")
}

model Refund {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chequeId    String        @map("cheque_id") @db.Uuid
  paymentId   String?       @map("payment_id") @db.Uuid
  cashierId   String        @map("cashier_id") @db.Uuid
  shiftId     String?       @map("shift_id") @db.Uuid
  initiatorId String        @map("initiator_id") @db.Uuid
  approverId  String        @map("approver_id") @db.Uuid
  method      PaymentMethod
  amount      Decimal       @db.Decimal(10, 2)
  reason      String        @db.Text
  processedAt DateTime      @default(now()) @map("processed_at") @db.Timestamptz(6)

  cheque    Cheque   @relation(fields: [chequeId], references: [id])
  payment   Payment? @relation(fields: [paymentId], references: [id])
  cashier   User     @relation("RefundCashier", fields: [cashierId], references: [id])
  initiator User     @relation("RefundInitiator", fields: [initiatorId], references: [id])
  approver  User     @relation("RefundApprover", fields: [approverId], references: [id])
  shift     Shift?   @relation(fields: [shiftId], references: [id])

  @@index([chequeId], map: "idx_refunds_cheque")
  @@index([shiftId], map: "idx_refunds_shift")
  @@map("refunds")
}

model ManagerApprovalRequest {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId      String                @map("venue_id") @db.Uuid
  chequeId     String                @map("cheque_id") @db.Uuid
  type         ApprovalRequestType
  status       ApprovalRequestStatus @default(pending)
  payload      Json
  reason       String                @db.Text
  cashierId    String                @map("cashier_id") @db.Uuid
  initiatorId  String                @map("initiator_id") @db.Uuid
  approverId   String?               @map("approver_id") @db.Uuid
  terminalId   String?               @map("terminal_id") @db.Uuid
  rejectReason String?               @map("reject_reason") @db.Text
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt   DateTime?             @map("resolved_at") @db.Timestamptz(6)

  venue     Venue  @relation(fields: [venueId], references: [id])
  cheque    Cheque @relation(fields: [chequeId], references: [id])
  cashier   User   @relation("ApprovalCashier", fields: [cashierId], references: [id])
  initiator User   @relation("ApprovalInitiator", fields: [initiatorId], references: [id])
  approver  User?  @relation("ApprovalResolver", fields: [approverId], references: [id])

  @@index([venueId, status], map: "idx_approval_requests_venue_status")
  @@index([chequeId], map: "idx_approval_requests_cheque")
  @@map("manager_approval_requests")
}

model VenueConfigAudit {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId   String   @map("venue_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  changes   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  venue Venue @relation(fields: [venueId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([venueId], map: "idx_venue_config_audit_venue")
  @@map("venue_config_audits")
}

model Shift {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId         String      @map("venue_id") @db.Uuid
  terminalId      String      @map("terminal_id") @db.Uuid
  cashierId       String      @map("cashier_id") @db.Uuid
  status          ShiftStatus @default(open)
  openFloat       Decimal     @map("open_float") @db.Decimal(10, 2)
  closeFloat      Decimal?    @map("close_float") @db.Decimal(10, 2)
  expectedCash    Decimal?    @map("expected_cash") @db.Decimal(10, 2)
  overShortAmount Decimal?    @map("over_short_amount") @db.Decimal(10, 2)
  openedAt        DateTime    @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt        DateTime?   @map("closed_at") @db.Timestamptz(6)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue    Venue        @relation(fields: [venueId], references: [id])
  terminal Terminal     @relation(fields: [terminalId], references: [id])
  cashier  User         @relation(fields: [cashierId], references: [id])
  payments Payment[]
  refunds  Refund[]
  events   ShiftEvent[]

  @@index([cashierId, status], map: "idx_shifts_cashier_status")
  @@index([terminalId, status], map: "idx_shifts_terminal_status")
  @@map("shifts")
}

model ShiftEvent {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId   String           @map("shift_id") @db.Uuid
  action    ShiftEventAction
  userId    String           @map("user_id") @db.Uuid
  details   Json?
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([shiftId], map: "idx_shift_events_shift")
  @@map("shift_events")
}

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId       String?  @map("venue_id") @db.Uuid
  actorId       String?  @map("actor_id") @db.Uuid
  actorUsername String?  @map("actor_username") @db.VarChar(100)
  action        String   @db.VarChar(64)
  entityType    String?  @map("entity_type") @db.VarChar(64)
  entityId      String?  @map("entity_id") @db.VarChar(64)
  summary       String   @db.VarChar(500)
  details       Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  venue Venue? @relation(fields: [venueId], references: [id])
  actor User?  @relation(fields: [actorId], references: [id])

  @@index([venueId, createdAt], map: "idx_audit_logs_venue_at")
  @@index([action, createdAt], map: "idx_audit_logs_action_at")
  @@map("audit_logs")
}

/// Internal ops / dev monitoring — terminal health, crashes, performance.
model OpsEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type       String   @db.VarChar(64)
  severity   String   @db.VarChar(16)
  source     String?  @db.VarChar(64)
  venueId    String?  @map("venue_id") @db.Uuid
  terminalId String?  @map("terminal_id") @db.Uuid
  title      String   @db.VarChar(200)
  message    String   @db.VarChar(1000)
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  venue    Venue?    @relation(fields: [venueId], references: [id])
  terminal Terminal? @relation(fields: [terminalId], references: [id])

  @@index([createdAt], map: "idx_ops_events_created")
  @@index([type, createdAt], map: "idx_ops_events_type_at")
  @@map("ops_events")
}
