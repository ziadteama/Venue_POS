NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Docker Compose default: hub_pos / hub_pos_dev @ localhost:5432 / hub_pos
# Local pgAdmin example:
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/hub_pos
REDIS_URL=redis://localhost:6379

JWT_PRIVATE_KEY_PATH=../../ops/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=../../ops/secrets/jwt-public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_ISSUER=hub-pos-system
JWT_AUDIENCE=hub-pos-clients

BCRYPT_ROUNDS=12
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

LOG_LEVEL=info

# Provider onboarding flag — set false for printer-only kitchens (no KDS app)
FEATURE_KDS_ENABLED=true

# Provider onboarding — set true when venue accepts manual (external terminal) card payments
FEATURE_MANUAL_CARD_PAYMENT=false
MANUAL_CARD_APPROVAL_THRESHOLD=500

# Provider onboarding — set true when staff may move fired lines between tables
FEATURE_LINE_TRANSFER=false

# Cheque discounts + refunds (US-5.6) — default ON; set false to disable
FEATURE_DISCOUNTS_ENABLED=true
FEATURE_REFUNDS_ENABLED=true

# Auto-print customer receipt on checkout via local agent (default ON)
FEATURE_AUTO_RECEIPT_PRINT=true

# Cross-venue billing (Phase 4) — anchor POS Cross-sell; group fire/pay, split tender, group % discount.
# Off by default; enable once billing pairs are configured on the dashboard. Card/split also needs FEATURE_MANUAL_CARD_PAYMENT=true.
FEATURE_CROSS_VENUE_BILLING=false
# Soft lock window (ms) an anchor holds while assembling a cross-venue settlement
CROSS_VENUE_LOCK_TTL_MS=30000
