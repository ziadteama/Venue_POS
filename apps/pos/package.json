    "react-i18next": "^15.2.0"
  },
  "devDependencies": {
    "@venue-pos/shared": "*",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.6",
    "wait-on": "^8.0.1"
  }
