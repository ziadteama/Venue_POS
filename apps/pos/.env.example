VITE_LOCAL_AGENT_URL=http://127.0.0.1:3456
VITE_API_URL=http://127.0.0.1:3000
VITE_TERMINAL_ID=00000000-0000-4000-8000-000000000001
VITE_TERMINAL_SECRET=dev-terminal-secret
ELECTRON_IS_KIOSK=false
# Production kiosk: true — or set by apps/watchdog when launched via WATCHDOG_POS_COMMAND
# Packaged till auto-update — default: GitHub Releases (ziadteama/Venue_POS)
# Private repo: copy .env.updater.example → .env.updater and set GH_TOKEN (see ops/linux/README.md)
# Override with a generic CDN feed:
# POS_UPDATE_FEED_URL=https://releases.example.com/venue-pos
# POS_GH_OWNER=ziadteama
# POS_GH_REPO=Venue_POS
