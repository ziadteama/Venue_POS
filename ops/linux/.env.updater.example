# GitHub token for POS auto-update (private repo: ziadteama/Venue_POS)
# Copy to /opt/venue-pos/pos/.env.updater and set your fine-grained PAT (Contents: Read).
# chmod 600 /opt/venue-pos/pos/.env.updater
# chown venuepos:venuepos /opt/venue-pos/pos/.env.updater
#
# GH_TOKEN=github_pat_xxxxxxxxxxxxxxxx
