# Copy to provision.env and fill from dev ops: Till provisioning -> Add terminal

API_URL=https://your-hub.onrender.com
TERMINAL_ID=00000000-0000-4000-8000-000000000001
TERMINAL_SECRET=your-terminal-secret
VENUE_ID=00000000-0000-4000-8000-000000000010

# Set true to force bcrypt/sqlite rebuild (Node 20 installed automatically)
# FORCE_NATIVE_REBUILD=false

# Optional offline Node 20 MSI (skip download from nodejs.org)
# NODE20_MSI_PATH=C:\Venue_POS\cache\node-v20.18.1-x64.msi

# setup-kiosk.bat + firewall-lockdown.bat
KIOSK_PASSWORD=YourSecureKioskPass1!
HUB_SERVER_IP=203.0.113.10
PRINTER_IPS=192.168.1.50
